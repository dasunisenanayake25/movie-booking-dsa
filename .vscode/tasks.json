{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Console App",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$sources = Get-ChildItem -Path './src' -Filter '*.cpp' | Where-Object { $_.Name -ne 'server.cpp' } | ForEach-Object { $_.FullName }; & 'C:/msys64/ucrt64/bin/g++.exe' '-fdiagnostics-color=always' '-g' '-std=c++14' '-I./include' @sources '-o' 'app.exe'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build Web Server",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$sources = Get-ChildItem -Path './src' -Filter '*.cpp' | Where-Object { $_.Name -ne 'main.cpp' } | ForEach-Object { $_.FullName }; & 'C:/msys64/ucrt64/bin/g++.exe' '-fdiagnostics-color=always' '-g' '-std=c++14' '-I./include' @sources '-lws2_32' '-o' 'server.exe'"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build"
        }
    ]
}
